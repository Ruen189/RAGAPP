# Профили compose по умолчанию (раскомментируйте один вариант):
# COMPOSE_PROFILES=llama-gpu-full
# COMPOSE_PROFILES=llama-cuda
# COMPOSE_PROFILES=llama-cpu-full

MODEL_HF=unsloth/Qwen3.5-9B-GGUF:UD-Q4_K_XL
MODEL_CONTEXT_SIZE=32768
ADMIN_LOGIN=admin
ADMIN_PASS=admin123
LLAMA_HOST=llama
LLAMA_PORT=8765
LLAMA_MODELS_DIR=${LOCALAPPDATA}/llama.cpp
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server
# TurboQuant fork (turbo2/3/4); официальный ghcr.io/ggml-org/llama.cpp:server-cuda turbo4 не поддерживает
LLAMA_CUDA_IMAGE=vito974/llama-cpp-turboquant:server-cuda12
LLAMA_PLATFORM=linux/amd64
LLAMA_N_GPU_LAYERS=0
LLAMA_THREADS=8
LLAMA_PARALLEL=1
# GPU (llama-cuda*): TurboQuant. CPU (llama*): q8_0 — стандартный llama.cpp без turbo*
KV_CACHE_TYPE_K=turbo4
KV_CACHE_TYPE_V=turbo3
KV_CACHE_TYPE_K_CPU=q8_0
KV_CACHE_TYPE_V_CPU=q8_0
LLAMA_EXTRA_ARGS=
MODEL_MULTIMODAL=True
MAX_QUEUE_SIZE=3
RAW_MESSAGES_SIZE=10
MESSAGES_SUMMARY_SIZE=5
SUMMARY_TOKENS_SIZE=12000
# True + profile llama-summary: отдельный контейнер с лёгкой моделью для сжатия контекста
USE_DEDICATED_SUMMARY_MODEL=False
# Используется контейнером llama-summary; при USE_DEDICATED_SUMMARY_MODEL=False на API не влияет
SUMMARY_MODEL_HF=unsloth/Qwen3.5-4B-GGUF:UD-Q4_K_XL
SUMMARY_MODEL_CONTEXT_SIZE=32768
SUMMARY_LLAMA_HOST=llama-summary
SUMMARY_LLAMA_PORT=8767
SUMMARY_LLAMA_N_GPU_LAYERS=999
SUMMARY_LLAMA_EXTRA_ARGS=
DATABASE_URL=postgresql+asyncpg://ragapp:ragapp@postgres:5432/ragapp
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=hashing-384
LOG_LEVEL=INFO
JWT_SECRET=test-secret-token
RESPONSE_MAX_TOKENS=3072
LLM_REPEAT_PENALTY=1.15
LLM_REPEAT_LAST_N=256
COMPOSE_PROFILES=llama-gpu-full